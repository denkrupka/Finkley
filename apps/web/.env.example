# =============================================================================
# Локальный .env.local — скопируй этот файл и заполни
# =============================================================================
# cp apps/web/.env.example apps/web/.env.local
# Никогда не коммить .env.local!
# =============================================================================

# Supabase (staging для разработки)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# Telegram userbot bridge (services/tg-userbot/, ADR-015)
VITE_TG_USERBOT_URL=https://userbot.finkley.app

# Stripe (test mode)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PRICE_ID=price_...

# Sentry (опц. для разработки, обязательно для прода)
VITE_SENTRY_DSN=

# Аналитика (опц.)
VITE_PLAUSIBLE_DOMAIN=
VITE_GOATCOUNTER_URL=

# Google OAuth client ID для GSI-флоу (signInWithIdToken).
# Получить: Google Cloud Console → APIs & Services → Credentials → OAuth Client (Web).
# В Authorized JavaScript origins указать: https://finkley.app, http://localhost:5173.
# В Supabase Dashboard → Auth → Providers → Google → "Authorized Client IDs" вставить тот же ID.
VITE_GOOGLE_CLIENT_ID=

# Telegram bot username (без @)
VITE_TELEGRAM_BOT_USERNAME=

# Базовый URL приложения
VITE_APP_URL=http://localhost:5173

# Web Push: VAPID public key (base64url, 87 chars). Парный private — в
# Supabase Edge Function secret VAPID_PRIVATE_KEY (туда же VAPID_SUBJECT).
# Сгенерить пару: `node scripts/generate-vapid.mjs` (см. подсказку в коммите).
VITE_VAPID_PUBLIC_KEY=
