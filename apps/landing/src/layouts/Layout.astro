---
import '../styles/global.css'
import { dict, LANGS } from '../i18n/dict'

interface Props {
  title: string
  description?: string
  /** Активный пункт топ-меню для подсветки */
  active?: 'home' | 'features' | 'pricing' | 'media' | 'privacy' | 'terms'
  /** Тип Open Graph — обычно website, для статей блога — article */
  ogType?: 'website' | 'article'
  /** Кастомное og:image (абсолютный URL или путь от корня) */
  image?: string
}

const {
  title,
  description = 'Finkley — учёт денег для салонов красоты. Видишь свою прибыль, а не только записи клиентов.',
  active = 'home',
  ogType = 'website',
  image,
} = Astro.props

// Дефолтный язык на статике — RU. Клиентский JS на DOMContentLoaded
// меняет тексты в [data-i18n="key"] если в localStorage другой выбор.
const t = dict.ru
const APP_URL = '/app/'

// Canonical URL для каждой страницы. Astro.site задан в astro.config.mjs
// (https://finkley.app). Astro.url.pathname — текущий путь.
const SITE_ORIGIN = (Astro.site ?? new URL('https://finkley.app')).origin
const canonicalUrl = new URL(Astro.url.pathname, SITE_ORIGIN).toString()
const ogImageUrl = new URL(image ?? '/og-image.svg', SITE_ORIGIN).toString()

// hreflang alternates. EN/PL пока живут как client-side switcher
// (см. dict.ts) — оба URL пока совпадают с RU. Когда сделаем SSR-маршруты
// /en/, /pl/ — обновить здесь.
const HREFLANGS = [
  { hreflang: 'ru', href: canonicalUrl },
  { hreflang: 'en', href: canonicalUrl },
  { hreflang: 'pl', href: canonicalUrl },
  { hreflang: 'x-default', href: canonicalUrl },
]

// JSON-LD: SoftwareApplication. €15/мес после 14-дневного trial.
// applicationCategory: FinanceApplication — Google понимает это как
// финансовый софт. offers.price = 15 EUR / month (recurring subscription).
const softwareLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Finkley',
  description: 'Учёт денег и аналитика для салонов красоты: визиты, расходы, зарплаты, прибыль, AI-подсказки.',
  applicationCategory: 'FinanceApplication',
  applicationSubCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  url: SITE_ORIGIN,
  inLanguage: ['ru', 'en', 'pl'],
  offers: {
    '@type': 'Offer',
    price: '15.00',
    priceCurrency: 'EUR',
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: '15.00',
      priceCurrency: 'EUR',
      billingDuration: 'P1M',
      billingIncrement: 1,
      unitText: 'month',
    },
    availability: 'https://schema.org/InStock',
    eligibleRegion: ['PL', 'EU'],
  },
  provider: {
    '@type': 'Organization',
    name: 'Finkley',
    url: SITE_ORIGIN,
  },
}

// JSON-LD: Organization (для sitelinks и knowledge graph).
const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Finkley',
  url: SITE_ORIGIN,
  logo: new URL('/logo.svg', SITE_ORIGIN).toString(),
  email: 'info@finkley.app',
  description: 'Финансы и операционка для салонов красоты.',
}
---

<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1A1A2E" />
    <meta name="application-name" content="Finkley" />
    <meta name="apple-mobile-web-app-title" content="Finkley" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Finkley — финансы салона" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:locale:alternate" content="pl_PL" />
    <meta property="og:site_name" content="Finkley" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Finkley — финансы салона" />
    <link rel="canonical" href={canonicalUrl} />
    {HREFLANGS.map((l) => <link rel="alternate" hreflang={l.hreflang} href={l.href} />)}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(softwareLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-brand-bg font-display text-brand-text antialiased">
    <header class="border-b border-brand-border bg-white">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6">
        <a href="/" class="flex items-center gap-2.5" aria-label="Finkley">
          <div
            class="grid size-8 place-items-center rounded-md bg-brand-navy text-sm font-extrabold tracking-tighter text-white"
            aria-hidden="true"
          >
            F
          </div>
          <span class="text-base font-bold tracking-tight text-brand-navy">Finkley</span>
        </a>

        <nav class="hidden items-center gap-7 md:flex">
          <a
            href="/"
            class={`text-sm font-medium ${active === 'home' ? 'text-brand-navy' : 'text-brand-text-muted hover:text-brand-text'}`}
            data-i18n="nav.product"
          >
            {t['nav.product']}
          </a>
          <a
            href="/features/integrations/"
            class={`text-sm font-medium ${active === 'features' ? 'text-brand-navy' : 'text-brand-text-muted hover:text-brand-text'}`}
            data-i18n="nav.features"
          >
            {t['nav.features']}
          </a>
          <a
            href="/pricing"
            class={`text-sm font-medium ${active === 'pricing' ? 'text-brand-navy' : 'text-brand-text-muted hover:text-brand-text'}`}
            data-i18n="nav.pricing"
          >
            {t['nav.pricing']}
          </a>
        </nav>

        <div class="flex items-center gap-3">
          <!-- Mobile burger toggle -->
          <button
            type="button"
            id="mobile-menu-btn"
            class="inline-flex size-10 items-center justify-center rounded-md border border-brand-border bg-white text-brand-navy md:hidden"
            aria-label="Menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden>
              <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            </svg>
          </button>
          <div class="relative">
            <button
              type="button"
              id="lang-switcher-btn"
              class="inline-flex h-9 items-center gap-1 rounded-md border border-brand-border bg-white px-2 text-sm font-medium text-brand-text-muted hover:bg-brand-bg"
              aria-label="Language"
            >
              <span id="lang-current-flag">🇷🇺</span>
              <span class="hidden sm:inline" id="lang-current-label">RU</span>
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden>
                <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" />
              </svg>
            </button>
            <ul
              id="lang-switcher-menu"
              class="absolute right-0 top-full mt-1 hidden min-w-[140px] rounded-md border border-brand-border bg-white shadow-lg"
              role="menu"
            >
              {
                LANGS.map((l) => (
                  <li>
                    <button
                      type="button"
                      data-lang={l.code}
                      class="lang-option flex w-full items-center gap-2 px-3 py-2 text-left text-sm text-brand-text hover:bg-brand-bg"
                    >
                      <span>{l.flag}</span>
                      <span>{l.label}</span>
                    </button>
                  </li>
                ))
              }
            </ul>
          </div>
          <a
            href={APP_URL + 'login'}
            class="hidden text-sm font-semibold text-brand-text-muted hover:text-brand-text md:inline"
            data-i18n="nav.login"
          >
            {t['nav.login']}
          </a>
          <a
            href={APP_URL + 'signup'}
            class="inline-flex h-10 items-center rounded-md bg-brand-navy px-4 text-sm font-semibold text-white hover:bg-brand-navy-soft"
            data-i18n="nav.signup"
          >
            {t['nav.signup']}
          </a>
        </div>
      </div>

      <!-- Mobile menu (collapsible) -->
      <div id="mobile-menu" class="hidden border-t border-brand-border bg-white md:hidden">
        <nav class="mx-auto flex max-w-7xl flex-col px-4 py-3 text-base font-medium">
          <a
            href="/"
            class={`flex h-12 items-center ${active === 'home' ? 'text-brand-navy' : 'text-brand-text'}`}
            data-i18n="nav.product"
          >
            {t['nav.product']}
          </a>
          <a
            href="/features/integrations/"
            class={`flex h-12 items-center ${active === 'features' ? 'text-brand-navy' : 'text-brand-text'}`}
            data-i18n="nav.features"
          >
            {t['nav.features']}
          </a>
          <a
            href="/pricing"
            class={`flex h-12 items-center ${active === 'pricing' ? 'text-brand-navy' : 'text-brand-text'}`}
            data-i18n="nav.pricing"
          >
            {t['nav.pricing']}
          </a>
          <a
            href={APP_URL + 'login'}
            class="flex h-12 items-center text-brand-text-muted"
            data-i18n="nav.login"
          >
            {t['nav.login']}
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-brand-border bg-white">
      <div
        class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-4 px-4 py-8 text-sm text-brand-text-muted sm:flex-row sm:items-center sm:px-6"
      >
        <div class="flex items-center gap-2.5">
          <div
            class="grid size-6 place-items-center rounded-md bg-brand-navy text-[11px] font-extrabold tracking-tighter text-white"
          >
            F
          </div>
          <span class="font-semibold text-brand-navy">Finkley</span>
          <span class="text-brand-text-faint" data-i18n="footer.rights">{t['footer.rights']}</span>
        </div>
        <nav class="flex flex-wrap gap-5">
          <a
            href="/media/"
            class={active === 'media' ? 'text-brand-navy' : 'hover:text-brand-text'}
            data-i18n="nav.media"
          >
            {t['nav.media']}
          </a>
          <a
            href="/privacy"
            class={active === 'privacy' ? 'text-brand-navy' : 'hover:text-brand-text'}
            data-i18n="footer.privacy"
          >
            {t['footer.privacy']}
          </a>
          <a
            href="/terms"
            class={active === 'terms' ? 'text-brand-navy' : 'hover:text-brand-text'}
            data-i18n="footer.terms"
          >
            {t['footer.terms']}
          </a>
          <a href="mailto:info@finkley.app" class="hover:text-brand-text">info@finkley.app</a>
        </nav>
      </div>
    </footer>

    <script>
      import { dict, type Lang } from '../i18n/dict'

      const LS_KEY = 'finkley.lang'

      function applyLang(lang: Lang) {
        const d = dict[lang]
        document.documentElement.lang = lang
        // Заменяем все элементы с data-i18n="key"
        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
          const key = el.dataset.i18n as keyof typeof d
          const v = d[key]
          if (v) el.textContent = v
        })
        // Обновляем индикатор в свитчере
        const flagMap: Record<Lang, string> = { ru: '🇷🇺', en: '🇬🇧', pl: '🇵🇱' }
        const labelMap: Record<Lang, string> = { ru: 'RU', en: 'EN', pl: 'PL' }
        const fEl = document.getElementById('lang-current-flag')
        const lEl = document.getElementById('lang-current-label')
        if (fEl) fEl.textContent = flagMap[lang]
        if (lEl) lEl.textContent = labelMap[lang]
      }

      function getStored(): Lang | null {
        try {
          const v = localStorage.getItem(LS_KEY)
          if (v === 'ru' || v === 'en' || v === 'pl') return v
        } catch {
          /* ignore */
        }
        return null
      }

      function detectBrowserLang(): Lang {
        const nav = (navigator.language || 'ru').toLowerCase()
        if (nav.startsWith('en')) return 'en'
        if (nav.startsWith('pl')) return 'pl'
        return 'ru'
      }

      // На старте — применяем сохранённый или авто-определённый язык
      document.addEventListener('DOMContentLoaded', () => {
        const stored = getStored()
        const initial = stored ?? detectBrowserLang()
        if (initial !== 'ru') applyLang(initial)
        else applyLang('ru')

        // Тоггл меню
        const btn = document.getElementById('lang-switcher-btn')
        const menu = document.getElementById('lang-switcher-menu')
        btn?.addEventListener('click', (e) => {
          e.stopPropagation()
          menu?.classList.toggle('hidden')
        })
        document.addEventListener('click', () => menu?.classList.add('hidden'))

        // Mobile burger menu toggle
        const mobBtn = document.getElementById('mobile-menu-btn')
        const mobMenu = document.getElementById('mobile-menu')
        mobBtn?.addEventListener('click', (e) => {
          e.stopPropagation()
          const isHidden = mobMenu?.classList.toggle('hidden')
          mobBtn.setAttribute('aria-expanded', isHidden ? 'false' : 'true')
        })

        // Выбор языка
        document.querySelectorAll<HTMLButtonElement>('.lang-option').forEach((b) => {
          b.addEventListener('click', () => {
            const lang = b.dataset.lang as Lang
            try {
              localStorage.setItem(LS_KEY, lang)
            } catch {
              /* ignore */
            }
            applyLang(lang)
            menu?.classList.add('hidden')
          })
        })
      })
    </script>
  </body>
</html>
