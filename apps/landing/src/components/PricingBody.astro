---
import type { PricingCopy } from '../i18n/content/pricing'

interface Props {
  copy: PricingCopy
  /** BCP-47 локаль для разделителя десятичных в цене (ru-RU / pl-PL). */
  locale?: string
}
const { copy, locale = 'ru-RU' } = Astro.props

/** Числовое значение месячной цены из строки тарифа («€19» → 19). */
function priceToNumber(price: string): number {
  return Number(price.replace(/[^\d.,]/g, '').replace(',', '.')) || 0
}
---

<section class="border-b border-brand-border bg-gradient-to-b from-white to-brand-bg">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24">
    <div class="text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-brand-navy sm:text-5xl">
        {copy.h1}
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-brand-text-muted">
        {copy.subtitle}
      </p>
      <ul
        class="mx-auto mt-6 flex max-w-2xl flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm font-semibold text-brand-text"
      >
        {
          copy.riskReversal.map((r) => (
            <li class="flex items-center gap-1.5">
              <span class="text-brand-sage">✓</span> {r}
            </li>
          ))
        }
      </ul>
    </div>

    <div
      class="mt-12 flex justify-center"
      data-pricing-toggle
      data-locale={locale}
      data-per-annual={copy.interval.perMonthAnnual}
    >
      <div class="inline-flex items-center gap-1 rounded-full bg-brand-bg p-1 ring-1 ring-brand-border">
        <button
          type="button"
          data-interval="year"
          class="inline-flex items-center gap-1.5 rounded-full px-4 py-1.5 text-sm font-semibold transition-colors"
        >
          {copy.interval.year}
          <span
            data-interval-badge
            class="rounded-full px-1.5 py-0.5 text-[10px] font-bold leading-none"
          >
            {copy.interval.yearBadge}
          </span>
        </button>
        <button
          type="button"
          data-interval="month"
          class="inline-flex items-center rounded-full px-4 py-1.5 text-sm font-semibold transition-colors"
        >
          {copy.interval.month}
        </button>
      </div>
    </div>

    {/* Все пакеты в один ряд: Бесплатный + 4 платных. Демо — не отдельный
        пакет, а инфо в подзаголовке героя («Демо 14 дней без карты»). */}
    <div class="mx-auto mt-8 grid max-w-7xl grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-5">
      {
        copy.freePlans.map((plan) => (
          <div class="flex flex-col rounded-xl border border-brand-border bg-white p-6 shadow-sm">
            <div class="text-lg font-extrabold tracking-tight text-brand-navy">{plan.name}</div>
            <div class="mt-3 flex items-baseline gap-1.5">
              <span class="font-mono text-4xl font-extrabold tracking-tight text-brand-navy">
                {plan.price}
              </span>
              <span class="text-base text-brand-text-muted">/ {plan.note}</span>
            </div>
            <p class="mt-3 min-h-[2.5rem] text-sm leading-relaxed text-brand-text-muted">
              {plan.blurb}
            </p>
            <ul class="mt-5 flex-1 space-y-2.5">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm text-brand-text">
                  <span class="mt-0.5 text-brand-sage">✓</span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <a
              href="/app/signup"
              class="mt-6 inline-flex h-11 w-full items-center justify-center rounded-lg border border-brand-navy text-sm font-bold text-brand-navy hover:bg-brand-bg"
            >
              {plan.cta}
            </a>
          </div>
        ))
      }
      {
        copy.paidPlans.map((plan) => (
          <div
            class={`relative flex flex-col rounded-xl bg-white p-6 ${
              plan.highlight
                ? 'border-2 border-brand-navy shadow-2xl shadow-brand-navy/10'
                : 'border border-brand-border shadow-sm'
            }`}
          >
            {plan.highlight && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="inline-flex items-center rounded-full bg-brand-navy px-3 py-1 text-xs font-bold uppercase tracking-wider text-white">
                  {copy.popularBadge}
                </span>
              </div>
            )}
            <div class="text-lg font-extrabold tracking-tight text-brand-navy">{plan.name}</div>
            <div class="mt-3 flex items-baseline gap-1.5">
              <span
                class="font-mono text-4xl font-extrabold tracking-tight text-brand-navy"
                data-plan-price
                data-monthly={priceToNumber(plan.price)}
              >
                {plan.price}
              </span>
              <span class="text-base text-brand-text-muted">{plan.period}</span>
            </div>
            <p
              class="mt-1 text-xs text-brand-text-muted"
              data-plan-annual-note
              hidden
            >
              {copy.interval.perMonthAnnual}
            </p>
            <p class="mt-3 min-h-[2.5rem] text-sm leading-relaxed text-brand-text-muted">
              {plan.blurb}
            </p>
            <ul class="mt-5 flex-1 space-y-2.5">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm text-brand-text">
                  <span class="mt-0.5 text-brand-sage">✓</span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <a
              href="/app/signup"
              class={`mt-6 inline-flex h-11 w-full items-center justify-center rounded-lg text-sm font-bold ${
                plan.highlight
                  ? 'bg-brand-navy text-white hover:bg-brand-navy-soft'
                  : 'border border-brand-navy text-brand-navy hover:bg-brand-bg'
              }`}
            >
              {plan.cta}
            </a>
          </div>
        ))
      }
    </div>

    <p class="mt-8 text-center text-sm text-brand-text-muted">
      {copy.finePrint}
    </p>
  </div>
</section>

<section class="bg-white">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-20">
    <h2 class="text-center text-2xl font-extrabold tracking-tight text-brand-navy">
      {copy.faqHeading}
    </h2>

    <div class="mt-8 space-y-3">
      {
        copy.faq.map((item) => (
          <details class="group rounded-md border border-brand-border bg-brand-bg p-5 open:bg-white open:shadow-sm">
            <summary class="flex cursor-pointer items-center justify-between text-base font-bold text-brand-navy">
              {item.q}
              <span class="ml-3 text-brand-text-muted transition-transform group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-brand-text-muted">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<script>
  // ADR-035 — переключатель ГОД/МЕСЯЦ. Цены ВСЕГДА «/мес»: ГОД (дефолт)
  // показывает скидочную месячную цену (полная × 0.85) + подпись «при оплате
  // за год»; МЕСЯЦ — полную месячную цену. Astro статичен → vanilla JS.
  function initPricingToggle() {
    const root = document.querySelector<HTMLElement>('[data-pricing-toggle]')
    if (!root) return

    const locale = root.dataset.locale || 'ru-RU'
    const buttons = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-interval]'))
    const priceEls = Array.from(document.querySelectorAll<HTMLElement>('[data-plan-price]'))
    const annualNotes = Array.from(document.querySelectorAll<HTMLElement>('[data-plan-annual-note]'))

    // Классы активной/неактивной кнопки (brand-токены, не хексы).
    const ACTIVE = ['bg-brand-navy', 'text-white', 'shadow-sm']
    const INACTIVE = ['text-brand-text-muted']
    const BADGE_ACTIVE = ['bg-brand-sage', 'text-white']
    const BADGE_INACTIVE = ['bg-brand-sage-soft', 'text-brand-sage']

    function formatEur(amount: number): string {
      const hasFraction = Math.round(amount * 100) % 100 !== 0
      const num = new Intl.NumberFormat(locale, {
        minimumFractionDigits: hasFraction ? 2 : 0,
        maximumFractionDigits: hasFraction ? 2 : 0,
      }).format(amount)
      return '€' + num
    }

    function apply(interval: 'year' | 'month') {
      for (const el of priceEls) {
        const monthly = Number(el.dataset.monthly || '0')
        // Годовая цена /мес округляется ВВЕРХ до целого евро (16.15 → 17):
        // показываем «ровные» суммы без копеек. Реальный годовой платёж —
        // точная −15% сумма (показывается на странице оплаты Stripe).
        const value = interval === 'year' ? Math.ceil(monthly * 0.85) : monthly
        el.textContent = formatEur(value)
      }
      for (const note of annualNotes) note.hidden = interval !== 'year'

      for (const btn of buttons) {
        const active = btn.dataset.interval === interval
        btn.classList.remove(...ACTIVE, ...INACTIVE)
        btn.classList.add(...(active ? ACTIVE : INACTIVE))
        const badge = btn.querySelector<HTMLElement>('[data-interval-badge]')
        if (badge) {
          badge.classList.remove(...BADGE_ACTIVE, ...BADGE_INACTIVE)
          badge.classList.add(...(active ? BADGE_ACTIVE : BADGE_INACTIVE))
        }
      }
    }

    for (const btn of buttons) {
      btn.addEventListener('click', () => apply(btn.dataset.interval === 'month' ? 'month' : 'year'))
    }

    // Дефолт — ГОД (скидочные цены /мес).
    apply('year')
  }

  initPricingToggle()
</script>
