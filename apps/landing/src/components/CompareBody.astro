---
import type { CompareCopy } from '../i18n/content/seo-pages'
import { localeFromPath, localizedPath } from '../i18n/routing'

interface Props {
  copy: CompareCopy
}
const { copy } = Astro.props

// Локаль текущей страницы (по префиксу пути). Внутренние ссылки на
// локализованные страницы строим через localizedPath; /media/ и /app/ —
// без префикса (PL-версии нет).
const locale = localeFromPath(Astro.url.pathname)
const integrationsHref = localizedPath('/features/integrations/', locale)
const useCasesHref = localizedPath('/use-cases/uchet-dlya-salona-krasoty/', locale)
const pricingHref = localizedPath('/pricing', locale)
const profitHref = '/media/kak-schitat-pribyl-salona/'
---

<!-- Hero + answer-блок -->
<section class="border-b border-brand-border bg-gradient-to-b from-white to-brand-bg">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24">
    <p class="text-sm font-semibold uppercase tracking-wider text-brand-teal">{copy.eyebrow}</p>
    <h1
      class="mt-4 max-w-3xl text-4xl font-extrabold tracking-tight text-brand-navy sm:text-5xl lg:text-6xl"
    >
      {copy.h1Pre}<span class="text-brand-sage">{copy.h1Accent}</span>
    </h1>
    <p
      class="mt-6 max-w-3xl rounded-lg border border-brand-border bg-white p-4 text-base leading-relaxed text-brand-text"
    >
      <strong>{copy.answerTitle}</strong>{copy.answerText}
    </p>
  </div>
</section>

<!-- Что делает Booksy -->
<section class="border-b border-brand-border bg-white">
  <div class="mx-auto max-w-3xl px-4 py-14 sm:px-6 sm:py-16">
    <h2 class="text-2xl font-bold tracking-tight text-brand-navy sm:text-3xl">{copy.booksyHeading}</h2>
    <p
      class="mt-5 rounded-lg border border-brand-border bg-brand-bg p-4 text-base leading-relaxed text-brand-text"
    >
      <strong>{copy.booksyLead}</strong>{copy.booksyIntro}
    </p>
    <ul class="mt-6 space-y-2 text-base text-brand-text-muted">
      {copy.booksyList.map((item) => <li>{item}</li>)}
    </ul>
  </div>
</section>

<!-- Что делает Finkley -->
<section class="border-b border-brand-border bg-brand-bg">
  <div class="mx-auto max-w-3xl px-4 py-14 sm:px-6 sm:py-16">
    <h2 class="text-2xl font-bold tracking-tight text-brand-navy sm:text-3xl">{copy.finkleyHeading}</h2>
    <p
      class="mt-5 rounded-lg border border-brand-border bg-white p-4 text-base leading-relaxed text-brand-text"
    >
      <strong>{copy.finkleyLead}</strong>{copy.finkleyIntro}
    </p>
    <ul class="mt-6 space-y-2 text-base text-brand-text-muted">
      {copy.finkleyList.map((item) => <li>{item}</li>)}
    </ul>
  </div>
</section>

<!-- Таблица сравнения -->
<section class="border-b border-brand-border bg-white">
  <div class="mx-auto max-w-4xl px-4 py-14 sm:px-6 sm:py-16">
    <h2 class="text-2xl font-bold tracking-tight text-brand-navy sm:text-3xl">
      {copy.tableHeading}
    </h2>
    <p
      class="mt-5 rounded-lg border border-brand-border bg-brand-bg p-4 text-base leading-relaxed text-brand-text"
    >
      <strong>{copy.tableLead}</strong>{copy.tableIntro}
    </p>
    <div class="mt-8 overflow-x-auto rounded-lg border border-brand-border">
      <table class="w-full border-collapse text-left text-sm">
        <thead>
          <tr class="bg-brand-navy text-white">
            <th class="px-4 py-3 font-semibold">{copy.tableColWhat}</th>
            <th class="px-4 py-3 text-center font-semibold">{copy.tableColFinkley}</th>
            <th class="px-4 py-3 text-center font-semibold">{copy.tableColBooksy}</th>
          </tr>
        </thead>
        <tbody>
          {
            copy.compare.map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-brand-bg'}>
                <td class="border-t border-brand-border px-4 py-3 font-medium text-brand-text">
                  {row.criterion}
                </td>
                <td class={`border-t border-brand-border px-4 py-3 text-center font-bold ${row.finkley === '✓' ? 'text-brand-sage' : 'text-brand-text-muted'}`}>
                  {row.finkley}
                </td>
                <td class={`border-t border-brand-border px-4 py-3 text-center font-bold ${row.booksy === '✓' ? 'text-brand-sage' : 'text-brand-text-muted'}`}>
                  {row.booksy}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
    <p class="mt-4 text-xs text-brand-text-faint">
      {copy.tableNote}
    </p>
  </div>
</section>

<!-- Можно ли вместо Booksy -->
<section class="border-b border-brand-border bg-brand-bg">
  <div class="mx-auto max-w-3xl px-4 py-14 sm:px-6 sm:py-16">
    <h2 class="text-2xl font-bold tracking-tight text-brand-navy sm:text-3xl">
      {copy.insteadHeading}
    </h2>
    <p
      class="mt-5 rounded-lg border border-brand-border bg-white p-4 text-base leading-relaxed text-brand-text"
    >
      <strong>{copy.insteadLead}</strong>{copy.insteadIntro}
    </p>
    <p class="mt-4 text-base leading-relaxed text-brand-text-muted">
      {copy.insteadText}
    </p>
  </div>
</section>

<!-- Как подключить -->
<section class="border-b border-brand-border bg-white">
  <div class="mx-auto max-w-3xl px-4 py-14 sm:px-6 sm:py-16">
    <h2 class="text-2xl font-bold tracking-tight text-brand-navy sm:text-3xl">
      {copy.connectHeading}
    </h2>
    <p
      class="mt-5 rounded-lg border border-brand-border bg-brand-bg p-4 text-base leading-relaxed text-brand-text"
    >
      <strong>{copy.connectLead}</strong>{copy.connectIntro}
    </p>
    <ol class="mt-6 list-decimal space-y-3 pl-6 text-base leading-relaxed text-brand-text-muted">
      {copy.steps.map((s) => <li>{s}</li>)}
    </ol>
    <p class="mt-6 text-base text-brand-text-muted">
      {copy.connectMorePre}
      <a href={integrationsHref} class="font-semibold text-brand-navy hover:underline">
        {copy.connectMoreLink}</a
      >{copy.connectMorePost}
    </p>
  </div>
</section>

<!-- FAQ -->
<section class="border-b border-brand-border bg-brand-bg">
  <div class="mx-auto max-w-3xl px-4 py-14 sm:px-6 sm:py-16">
    <h2 class="text-center text-2xl font-bold tracking-tight text-brand-navy sm:text-3xl">
      {copy.faqHeading}
    </h2>
    <div class="mt-10 space-y-3">
      {
        copy.faq.map((item) => (
          <details class="group rounded-md border border-brand-border bg-white p-5 open:shadow-sm">
            <summary class="flex cursor-pointer items-center justify-between text-base font-bold text-brand-navy">
              {item.q}
              <span class="ml-3 text-brand-text-muted transition-transform group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-brand-text-muted">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<!-- Внутренние ссылки -->
<section class="border-b border-brand-border bg-white">
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <p class="text-base text-brand-text-muted">
      {copy.relatedPre}
      <a href={useCasesHref} class="font-semibold text-brand-navy hover:underline"
        >{copy.relatedUseCases}</a
      >{copy.relatedSep1}
      <a href={profitHref} class="font-semibold text-brand-navy hover:underline"
        >{copy.relatedProfit}</a
      >{copy.relatedSep2}
      <a href={pricingHref} class="font-semibold text-brand-navy hover:underline">{copy.relatedPricing}</a>{copy.relatedPost}
    </p>
  </div>
</section>

<!-- CTA -->
<section class="bg-brand-navy text-white">
  <div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
    <h2 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
      {copy.ctaHeading}
    </h2>
    <p class="mt-4 text-base text-white/70">
      {copy.ctaText}
    </p>
    <a
      href="/app/signup"
      class="mt-8 inline-flex h-12 items-center rounded-lg bg-brand-sage px-8 text-sm font-bold hover:bg-brand-sage/90"
    >
      {copy.ctaButton}
    </a>
    <p class="mt-3 text-xs text-white/60">{copy.ctaMicrocopy}</p>
  </div>
</section>
