---
import type { MessengerCopy } from '../i18n/content/features'

interface Props {
  copy: MessengerCopy
}
const { copy } = Astro.props
const mockInitials = copy.mock.name
  .split(' ')
  .map((w) => w[0])
  .join('')
  .slice(0, 2)
---

<!-- Hero -->
<section class="border-b border-brand-border bg-gradient-to-b from-white to-brand-bg">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24">
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-teal">
          {copy.eyebrow}
        </p>
        <h1
          class="mt-4 text-4xl font-extrabold tracking-tight text-brand-navy sm:text-5xl lg:text-6xl"
        >
          {copy.h1.pre}{copy.h1.br && <br />}
          <span class="text-brand-sage">{copy.h1.accent}</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-brand-text-muted">
          {copy.subtitle}
        </p>
        <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row sm:items-center">
          <a
            href="/app/signup"
            class="inline-flex h-12 items-center rounded-lg bg-brand-navy px-6 text-sm font-bold text-white shadow-lg shadow-brand-navy/20 hover:bg-brand-navy-soft"
          >
            {copy.ctaPrimary}
          </a>
          <a
            href="/pricing"
            class="inline-flex h-12 items-center rounded-lg px-4 text-sm font-semibold text-brand-text-muted hover:text-brand-text"
          >
            {copy.ctaSecondary}
          </a>
        </div>
      </div>

      <div
        class="rounded-2xl border border-brand-border bg-white p-6 shadow-xl shadow-brand-navy/5"
      >
        <div class="flex items-center justify-between border-b border-brand-border pb-3">
          <div class="flex items-center gap-3">
            <div
              class="grid size-10 place-items-center rounded-full bg-emerald-100 text-emerald-700"
            >
              {mockInitials}
            </div>
            <div>
              <p class="text-sm font-bold text-brand-navy">{copy.mock.name}</p>
              <p class="text-xs text-brand-text-muted">
                <span class="text-rose-500">●</span> {copy.mock.status}
              </p>
            </div>
          </div>
          <button
            class="inline-flex h-8 items-center rounded-md border border-brand-border px-3 text-xs font-semibold text-brand-text"
          >
            {copy.mock.visitButton}
          </button>
        </div>
        <div class="mt-4 space-y-3">
          <div class="max-w-[80%] rounded-2xl rounded-tl-md bg-brand-bg px-4 py-2 text-sm">
            {copy.mock.msg1}
          </div>
          <div
            class="ml-auto max-w-[80%] rounded-2xl rounded-tr-md bg-brand-navy px-4 py-2 text-sm text-white"
          >
            {copy.mock.msg2}
          </div>
          <div class="max-w-[80%] rounded-2xl rounded-tl-md bg-brand-bg px-4 py-2 text-sm">
            {copy.mock.msg3}
          </div>
        </div>
        <div class="mt-4 flex items-center gap-2 border-t border-brand-border pt-3">
          <input
            placeholder={copy.mock.inputPlaceholder}
            class="h-10 flex-1 rounded-md border border-brand-border bg-white px-3 text-sm"
            disabled
          />
          <button class="grid size-10 place-items-center rounded-md bg-brand-navy text-white">
            →
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Channels -->
<section class="border-b border-brand-border bg-white">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20">
    <h2 class="text-center text-3xl font-extrabold tracking-tight text-brand-navy sm:text-4xl">
      {copy.channelsHeading}
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-base text-brand-text-muted">
      {copy.channelsSubtitle}
    </p>

    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        copy.channels.map((ch) => (
          <div class="rounded-xl border border-brand-border bg-white p-6">
            <div
              class="grid size-12 place-items-center rounded-lg"
              style={`background: ${ch.bg}; color: white;`}
            >
              {ch.glyph}
            </div>
            <h3 class="mt-4 text-lg font-bold text-brand-navy">{ch.name}</h3>
            <p class="mt-2 text-sm text-brand-text-muted">{ch.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- Highlights -->
<section class="border-b border-brand-border bg-brand-bg">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20">
    <h2 class="text-3xl font-extrabold tracking-tight text-brand-navy sm:text-4xl">
      {copy.highlightsHeading}
    </h2>

    <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2">
      {
        copy.highlights.map((h) => (
          <div>
            <div class="text-2xl">{h.emoji}</div>
            <h3 class="mt-2 text-lg font-bold text-brand-navy">{h.title}</h3>
            <p class="mt-2 text-sm text-brand-text-muted leading-relaxed">{h.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bg-white">
  <div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
    <h2 class="text-3xl font-extrabold tracking-tight text-brand-navy sm:text-4xl">
      {copy.cta.heading}
    </h2>
    <p class="mt-4 text-base text-brand-text-muted">
      {copy.cta.text}
    </p>
    <a
      href="/app/signup"
      class="mt-8 inline-flex h-12 items-center rounded-lg bg-brand-navy px-8 text-sm font-bold text-white shadow-lg shadow-brand-navy/20 hover:bg-brand-navy-soft"
    >
      {copy.cta.button}
    </a>
  </div>
</section>
