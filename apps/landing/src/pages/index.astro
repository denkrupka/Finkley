---
import Layout from '../layouts/Layout.astro'
import HomeBody from '../components/HomeBody.astro'
import { buildHomeJsonLd, homeContent } from '../i18n/content/home'

const copy = homeContent.ru
const jsonLd = buildHomeJsonLd(copy)
---

<Layout
  title={copy.title}
  description={copy.description}
  active="home"
  lang="ru"
  localized
  jsonLd={jsonLd}
>
  <HomeBody copy={copy} />
</Layout>
