---
import Layout from '../layouts/Layout.astro'

const FEATURES = [
  {
    title: 'Прибыль в одном клике',
    text: 'Главная карточка дашборда — твоя чистая прибыль за месяц. Не записи клиентов, не загрузка кресел — деньги в кармане.',
    emoji: '💰',
  },
  {
    title: 'Ввод визита за 10 секунд',
    text: 'Мастер, услуга, сумма, тип оплаты — и всё. Большой жёлтый инпут под цифру и одна кнопка «Сохранить».',
    emoji: '⚡',
  },
  {
    title: 'Расходы, которые видно',
    text: 'Аренда, зарплата, материалы, реклама. Структура по категориям — сразу понятно, куда уходят деньги.',
    emoji: '📊',
  },
  {
    title: 'Мастера и услуги',
    text: 'Кто принёс сколько за месяц. Маржа по услугам — какие выгодные, какие тянут вниз.',
    emoji: '👥',
  },
  {
    title: 'Без бухгалтера',
    text: 'Не заменяет бухгалтера для налогов. Заменяет Excel, в котором ты ведёшь свои настоящие цифры.',
    emoji: '✂️',
  },
  {
    title: 'Все данные в ЕС',
    text: 'Серверы во Франкфурте, шифрование at-rest, GDPR-compliance. Никакой передачи третьим лицам.',
    emoji: '🔒',
  },
]

const FAQ = [
  {
    q: 'Это же просто ещё один Excel?',
    a: 'Excel — отличный инструмент, но он не считает прибыль автоматически. Finkley делает это за тебя и показывает цифру первой строкой каждый раз, когда ты заходишь.',
  },
  {
    q: 'Чем это отличается от Booksy?',
    a: 'Booksy — система записи клиентов. Finkley — управленческий учёт. Можно использовать вместе: Booksy для записи, Finkley для денег.',
  },
  {
    q: 'Сколько стоит?',
    a: '€15/мес. 14 дней бесплатно без карты — попробуй, прежде чем платить.',
  },
  {
    q: 'А если я не хочу платить?',
    a: 'Без оплаты после триала аккаунт переходит в read-only — можно смотреть данные, но не добавлять новые. Подписаться можно в любой момент.',
  },
  {
    q: 'А мои данные?',
    a: 'Все данные хранятся в Supabase в ЕС (Франкфурт). При удалении аккаунта — 30 дней grace-период, потом hard delete. Можно экспортировать всё в CSV.',
  },
  {
    q: 'А если у меня несколько салонов?',
    a: 'Один аккаунт — несколько салонов с переключателем сверху. Каждый салон считается отдельно. Цена — €15/мес за каждый салон.',
  },
]
---

<Layout title="Finkley — прибыль твоего салона в одном месте" active="home">
  <!-- Hero -->
  <section class="border-b border-brand-border bg-gradient-to-b from-white to-brand-bg">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24">
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wider text-brand-teal">
            Управленческий учёт для салонов красоты
          </p>
          <h1
            class="mt-4 text-4xl font-extrabold tracking-tight text-brand-navy sm:text-5xl lg:text-6xl"
          >
            Booksy показывает клиентов.<br />
            <span class="text-brand-sage">Мы показываем твою прибыль.</span>
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-brand-text-muted">
            Ввела визит — увидела цифру. Каждое утро понятно, сколько ты заработала вчера и в этом
            месяце. Никаких таблиц, формул и бухгалтера для рутины.
          </p>
          <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row sm:items-center">
            <a
              href="/app/signup"
              class="inline-flex h-12 items-center rounded-lg bg-brand-navy px-6 text-sm font-bold text-white shadow-lg shadow-brand-navy/20 hover:bg-brand-navy-soft"
            >
              Начать бесплатно — 14 дней
            </a>
            <a
              href="/pricing"
              class="inline-flex h-12 items-center rounded-lg px-4 text-sm font-semibold text-brand-text-muted hover:text-brand-text"
            >
              Цены и тарифы →
            </a>
          </div>
          <p class="mt-3 text-xs text-brand-text-faint">
            Без карты на старте · €15/мес после триала · Отменить в один клик
          </p>
        </div>

        <!-- Hero «скриншот» — реальный SVG-mock дашборда -->
        <div class="relative">
          <div
            class="rounded-xl border border-brand-border bg-white p-5 shadow-2xl shadow-brand-navy/15"
          >
            <div class="mb-4 flex items-center justify-between">
              <span class="text-xs font-bold text-brand-text-muted">Май 2026</span>
              <span
                class="rounded-full bg-brand-sage-soft px-2 py-0.5 text-[10px] font-bold text-brand-sage"
                >+12% к апрелю</span
              >
            </div>
            <div class="grid grid-cols-3 gap-3">
              <div class="rounded-md border border-brand-border p-3">
                <div class="text-[10px] font-semibold text-brand-text-muted">Выручка</div>
                <div class="mt-1 font-mono text-lg font-bold text-brand-sage">€2 840</div>
              </div>
              <div class="rounded-md border border-brand-border p-3">
                <div class="text-[10px] font-semibold text-brand-text-muted">Расходы</div>
                <div class="mt-1 font-mono text-lg font-bold text-brand-red">−€1 205</div>
              </div>
              <div class="rounded-md bg-brand-navy p-3 text-white">
                <div class="text-[10px] font-bold uppercase tracking-wider opacity-65">Прибыль</div>
                <div class="mt-1 font-mono text-2xl font-bold">€1 635</div>
              </div>
            </div>
            <div class="mt-4 space-y-2">
              {
                [
                  { name: 'Аня', value: 1240 },
                  { name: 'Катя', value: 980 },
                  { name: 'Марина', value: 420 },
                ].map((m) => (
                  <div class="flex items-center gap-2">
                    <div class="w-12 text-xs font-semibold text-brand-text">{m.name}</div>
                    <div class="h-2 flex-1 overflow-hidden rounded-full bg-brand-bg">
                      <div
                        class="h-full bg-gradient-to-r from-brand-teal to-brand-navy"
                        style={`width: ${(m.value / 1240) * 100}%`}
                      />
                    </div>
                    <div class="font-mono text-xs font-bold text-brand-navy">€{m.value}</div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="border-b border-brand-border bg-white">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20">
      <h2 class="text-center text-3xl font-extrabold tracking-tight text-brand-navy sm:text-4xl">
        Что внутри
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-center text-base text-brand-text-muted">
        Все необходимые цифры в одном месте, без обучения.
      </p>
      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          FEATURES.map((f) => (
            <div class="rounded-lg border border-brand-border bg-brand-bg p-6 transition-colors hover:bg-white hover:shadow-md">
              <div class="text-3xl">{f.emoji}</div>
              <h3 class="mt-4 text-lg font-bold tracking-tight text-brand-navy">{f.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-brand-text-muted">{f.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Не заменяем — секция -->
  <section class="bg-brand-bg">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20">
      <h2 class="text-center text-3xl font-extrabold tracking-tight text-brand-navy sm:text-4xl">
        Что мы НЕ делаем
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-center text-base text-brand-text-muted">
        Finkley — про деньги. Для остального — другие инструменты.
      </p>
      <div class="mx-auto mt-10 grid max-w-3xl grid-cols-1 gap-4 sm:grid-cols-2">
        {
          [
            ['Не заменяем Booksy', 'Записи клиентов остаются там, где привыкла'],
            ['Не делаем налоговую', 'Бухгалтер всё ещё нужен для отчётности'],
            ['Не отвечаем за инвентарь', 'Сколько лаков на полке — другой вопрос'],
            ['Не считаем зарплату по часам', 'Только % от выручки на старте'],
          ].map(([title, sub]) => (
            <div class="flex items-start gap-3 rounded-md border border-brand-border bg-white p-4">
              <span class="mt-0.5 text-lg">✗</span>
              <div>
                <div class="text-sm font-bold text-brand-navy">{title}</div>
                <div class="text-xs text-brand-text-muted">{sub}</div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-brand-border bg-white">
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-20">
      <h2 class="text-center text-3xl font-extrabold tracking-tight text-brand-navy sm:text-4xl">
        Частые вопросы
      </h2>
      <div class="mt-10 space-y-3">
        {
          FAQ.map((item) => (
            <details class="group rounded-md border border-brand-border bg-brand-bg p-5 open:bg-white open:shadow-sm">
              <summary class="flex cursor-pointer items-center justify-between text-base font-bold text-brand-navy">
                {item.q}
                <span class="ml-3 text-brand-text-muted transition-transform group-open:rotate-45">
                  +
                </span>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-brand-text-muted">{item.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA bottom -->
  <section class="bg-brand-navy text-white">
    <div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
      <h2 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
        Попробуй за 14 дней. Не понравится — закроешь.
      </h2>
      <p class="mt-4 text-base text-white/70">
        Без карты на старте. €15/мес после триала, можно отменить в один клик.
      </p>
      <a
        href="/app/signup"
        class="mt-8 inline-flex h-12 items-center rounded-lg bg-brand-sage px-6 text-sm font-bold hover:bg-brand-sage/90"
      >
        Начать бесплатно
      </a>
    </div>
  </section>
</Layout>
