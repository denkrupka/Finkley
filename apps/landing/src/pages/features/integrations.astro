---
import Layout from '../../layouts/Layout.astro'
import IntegrationsBody from '../../components/IntegrationsBody.astro'
import { buildFeatureBreadcrumb, featuresContent } from '../../i18n/content/features'

const copy = featuresContent.ru.integrations
const SITE_ORIGIN = (Astro.site ?? new URL('https://finkley.app')).origin
const breadcrumbLd = buildFeatureBreadcrumb(
  copy.breadcrumbHome,
  copy.breadcrumbSelf,
  new URL('/features/integrations/', SITE_ORIGIN).toString(),
  SITE_ORIGIN + '/',
)
---

<Layout
  title={copy.title}
  description={copy.description}
  active="features"
  lang="ru"
  localized
  jsonLd={breadcrumbLd}
>
  <IntegrationsBody copy={copy} />
</Layout>
