---
import Layout from '../../layouts/Layout.astro'
import { getCollection, type CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('media', ({ data }) => !data.draft)
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

const { post } = Astro.props as { post: CollectionEntry<'media'> }
const { Content } = await post.render()

function fmt(d: Date): string {
  return new Intl.DateTimeFormat('ru-RU', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(d)
}
---

<Layout title={`${post.data.title} — Finkley`} description={post.data.description} active="media">
  <article>
    <header class="border-b border-brand-border bg-white">
      <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
        <a href="/media/" class="text-sm font-semibold text-brand-teal hover:underline">← Все статьи</a>
        <p class="mt-6 text-xs font-semibold text-brand-text-muted">
          {fmt(post.data.date)} · {post.data.author}
        </p>
        <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-brand-navy sm:text-4xl">
          {post.data.title}
        </h1>
        <p class="mt-3 text-lg text-brand-text-muted">{post.data.description}</p>
        {post.data.tags && post.data.tags.length > 0 ? (
          <ul class="mt-5 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <li class="rounded-full bg-brand-bg px-2.5 py-0.5 text-[11px] font-semibold text-brand-text-muted">
                #{tag}
              </li>
            ))}
          </ul>
        ) : null}
      </div>
    </header>
    <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
      <div class="prose prose-slate max-w-none prose-h2:text-brand-navy prose-h3:text-brand-navy prose-a:text-brand-teal">
        <Content />
      </div>
      <div class="mt-12 rounded-xl border border-brand-border bg-white p-6 text-center">
        <p class="text-lg font-bold text-brand-navy">Веди финансы салона как пилот — на приборах.</p>
        <p class="mt-2 text-sm text-brand-text-muted">
          14 дней бесплатно. Без карты. Подключение Booksy и банка за пару минут.
        </p>
        <a
          href="/app/signup"
          class="mt-4 inline-flex h-11 items-center rounded-md bg-brand-navy px-5 text-sm font-semibold text-white hover:bg-brand-navy-soft"
        >
          Попробовать Finkley
        </a>
      </div>
    </div>
  </article>
</Layout>
