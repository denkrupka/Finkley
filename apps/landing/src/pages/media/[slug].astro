---
import Layout from '../../layouts/Layout.astro'
import { getCollection, type CollectionEntry } from 'astro:content'
import { marked } from 'marked'
import { loadDbPosts, type DbPost } from '../../lib/db-posts'

type MdPost = { kind: 'md'; entry: CollectionEntry<'media'> }
type DbProp = { kind: 'db'; post: DbPost }
type PostProp = MdPost | DbProp

export async function getStaticPaths() {
  const mdPosts = await getCollection('media', ({ data }) => !data.draft)
  const dbPosts = await loadDbPosts()
  const seen = new Set<string>()
  const paths: Array<{ params: { slug: string }; props: PostProp }> = []
  for (const entry of mdPosts) {
    seen.add(entry.slug)
    paths.push({ params: { slug: entry.slug }, props: { kind: 'md', entry } })
  }
  for (const dbp of dbPosts) {
    if (seen.has(dbp.slug)) continue
    paths.push({ params: { slug: dbp.slug }, props: { kind: 'db', post: dbp } })
  }
  return paths
}

const props = Astro.props as PostProp

const data = props.kind === 'md' ? props.entry.data : props.post.data
// DB-посты из админки хранят контент в body_html (TipTap), body_md обычно пуст.
// Рендерим готовый HTML; на legacy-посты только с body_md — fallback через marked.
const renderedHtml =
  props.kind === 'md'
    ? null
    : props.post.bodyHtml && props.post.bodyHtml.trim()
      ? props.post.bodyHtml
      : (marked.parse(props.post.body ?? '', { async: false }) as string)

const ContentComp =
  props.kind === 'md' ? (await props.entry.render()).Content : null

function fmt(d: Date): string {
  return new Intl.DateTimeFormat('ru-RU', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(d)
}

const post = { data }

const SITE_ORIGIN = (Astro.site ?? new URL('https://finkley.app')).origin
const articleUrl = new URL(Astro.url.pathname, SITE_ORIGIN).toString()
const imageAbs = new URL(post.data.cover ?? '/og-image.svg', SITE_ORIGIN).toString()

// BlogPosting schema — author/datePublished для Google + извлекаемость в AI-движках.
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  image: imageAbs,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  inLanguage: 'ru',
  url: articleUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  author: { '@type': 'Organization', name: post.data.author ?? 'Finkley', url: SITE_ORIGIN },
  publisher: {
    '@type': 'Organization',
    name: 'Finkley',
    logo: { '@type': 'ImageObject', url: new URL('/logo.svg', SITE_ORIGIN).toString() },
  },
  keywords: (post.data.tags ?? []).join(', '),
}

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: SITE_ORIGIN + '/' },
    { '@type': 'ListItem', position: 2, name: 'Блог', item: new URL('/media/', SITE_ORIGIN).toString() },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: articleUrl },
  ],
}
---

<Layout
  title={`${post.data.title} — Finkley`}
  description={post.data.description}
  image={post.data.cover}
  ogType="article"
  active="media"
  jsonLd={[articleLd, breadcrumbLd]}
>
  <article>
    <header class="border-b border-brand-border bg-white">
      <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
        <a href="/media/" class="text-sm font-semibold text-brand-teal hover:underline">← Все статьи</a>
        <p class="mt-6 text-xs font-semibold text-brand-text-muted">
          {fmt(post.data.date)} · {post.data.author}
        </p>
        <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-brand-navy sm:text-4xl">
          {post.data.title}
        </h1>
        <p class="mt-3 text-lg text-brand-text-muted">{post.data.description}</p>
        {post.data.tags && post.data.tags.length > 0 ? (
          <ul class="mt-5 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <li class="rounded-full bg-brand-bg px-2.5 py-0.5 text-[11px] font-semibold text-brand-text-muted">
                #{tag}
              </li>
            ))}
          </ul>
        ) : null}
      </div>
    </header>
    <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
      {post.data.cover ? (
        <img
          src={post.data.cover}
          alt={post.data.title}
          class="mb-8 aspect-[16/9] w-full rounded-xl border border-brand-border object-cover"
        />
      ) : null}
      <div class="prose prose-slate max-w-none prose-h2:text-brand-navy prose-h3:text-brand-navy prose-a:text-brand-teal">
        {ContentComp ? <ContentComp /> : <div set:html={renderedHtml ?? ''} />}
      </div>
      <div class="mt-12 rounded-xl border border-brand-border bg-white p-6 text-center">
        <p class="text-lg font-bold text-brand-navy">Веди финансы салона как пилот — на приборах.</p>
        <p class="mt-2 text-sm text-brand-text-muted">
          14 дней бесплатно. Без карты. Подключение Booksy и банка за пару минут.
        </p>
        <a
          href="/app/signup"
          class="mt-4 inline-flex h-11 items-center rounded-md bg-brand-navy px-5 text-sm font-semibold text-white hover:bg-brand-navy-soft"
        >
          Попробовать Finkley
        </a>
      </div>
    </div>
  </article>
</Layout>
