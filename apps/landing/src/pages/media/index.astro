---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { loadDbPosts } from '../../lib/db-posts'

// Источников два:
//   1. Markdown-файлы в src/content/media — committed в git.
//   2. media_posts в Supabase — управляются через app /admin/media админкой.
// Мерджим. По slug DB-пост перебивает markdown (на случай редакции).
const mdPosts = await getCollection('media', ({ data }) => !data.draft)
const dbPosts = await loadDbPosts()
const bySlug = new Map<string, { slug: string; data: { title: string; description: string; date: Date; cover?: string; tags: string[]; author?: string; draft?: boolean }; source: 'md' | 'db' }>()
for (const p of mdPosts) {
  bySlug.set(p.slug, { slug: p.slug, data: { ...p.data, draft: !!p.data.draft }, source: 'md' })
}
for (const p of dbPosts) bySlug.set(p.slug, { ...p, source: 'db' })
const posts = Array.from(bySlug.values()).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)

function fmt(d: Date): string {
  return new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }).format(d)
}

const SITE_ORIGIN = (Astro.site ?? new URL('https://finkley.app')).origin

// Blog schema со списком статей — помогает Google/AI понять это как блог-хаб
// и подтягивать отдельные статьи в выдачу.
const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Блог Finkley — финансы салона красоты',
  description: 'Статьи о финансовом учёте, маржинальности и операционке салона красоты.',
  url: new URL('/media/', SITE_ORIGIN).toString(),
  inLanguage: 'ru',
  publisher: { '@type': 'Organization', name: 'Finkley', url: SITE_ORIGIN },
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    description: p.data.description,
    datePublished: p.data.date.toISOString(),
    url: new URL(`/media/${p.slug}/`, SITE_ORIGIN).toString(),
  })),
}

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: SITE_ORIGIN + '/' },
    { '@type': 'ListItem', position: 2, name: 'Блог', item: new URL('/media/', SITE_ORIGIN).toString() },
  ],
}
---

<Layout
  title="Блог Finkley — финансы и учёт салона красоты"
  description="Статьи о финансовом учёте, марже, прибыли и операционке салона красоты. Простыми словами, без воды — то, что реально влияет на ваш P&L."
  active="media"
  jsonLd={[blogLd, breadcrumbLd]}
>
  <section class="border-b border-brand-border bg-gradient-to-b from-white to-brand-bg">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-20">
      <p class="text-xs font-bold uppercase tracking-wider text-brand-teal">Media</p>
      <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-brand-navy sm:text-5xl">
        Финансы салона — простыми словами
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-brand-text-muted">
        Учёт, маржа, прогноз, операционные ошибки. Без воды — то, что реально влияет на ваш P&L.
      </p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
      {posts.length === 0 ? (
        <p class="text-brand-text-muted text-center">Статьи скоро появятся.</p>
      ) : (
        <ul class="flex flex-col gap-6">
          {posts.map((post) => (
            <li>
              <a
                href={`/media/${post.slug}/`}
                class="block rounded-xl border border-brand-border bg-white p-6 transition hover:border-brand-navy hover:shadow-lg"
              >
                {post.data.cover ? (
                  <img
                    src={post.data.cover}
                    alt={post.data.title}
                    loading="lazy"
                    class="mb-4 aspect-[16/9] w-full rounded-lg border border-brand-border object-cover"
                  />
                ) : null}
                <p class="text-xs font-semibold text-brand-teal">{fmt(post.data.date)}</p>
                <h2 class="mt-1 text-xl font-bold tracking-tight text-brand-navy sm:text-2xl">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-brand-text-muted">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 ? (
                  <ul class="mt-3 flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <li class="rounded-full bg-brand-bg px-2 py-0.5 text-[11px] font-semibold text-brand-text-muted">
                        #{tag}
                      </li>
                    ))}
                  </ul>
                ) : null}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</Layout>
