---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'

// Все опубликованные статьи (draft=false), сортированы по дате desc.
const allPosts = await getCollection('media', ({ data }) => !data.draft)
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

function fmt(d: Date): string {
  return new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }).format(d)
}
---

<Layout title="Finkley — медиа и блог о финансах салона" description="Статьи о финансовом учёте, маржинальности и операционке салона красоты." active="media">
  <section class="border-b border-brand-border bg-gradient-to-b from-white to-brand-bg">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-20">
      <p class="text-xs font-bold uppercase tracking-wider text-brand-teal">Media</p>
      <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-brand-navy sm:text-5xl">
        Финансы салона — простыми словами
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-brand-text-muted">
        Учёт, маржа, прогноз, операционные ошибки. Без воды — то, что реально влияет на ваш P&L.
      </p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
      {posts.length === 0 ? (
        <p class="text-brand-text-muted text-center">Статьи скоро появятся.</p>
      ) : (
        <ul class="flex flex-col gap-6">
          {posts.map((post) => (
            <li>
              <a
                href={`/media/${post.slug}/`}
                class="block rounded-xl border border-brand-border bg-white p-6 transition hover:border-brand-navy hover:shadow-lg"
              >
                <p class="text-xs font-semibold text-brand-teal">{fmt(post.data.date)}</p>
                <h2 class="mt-1 text-xl font-bold tracking-tight text-brand-navy sm:text-2xl">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-brand-text-muted">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 ? (
                  <ul class="mt-3 flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <li class="rounded-full bg-brand-bg px-2 py-0.5 text-[11px] font-semibold text-brand-text-muted">
                        #{tag}
                      </li>
                    ))}
                  </ul>
                ) : null}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</Layout>
