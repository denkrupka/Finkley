---
import Layout from '../../layouts/Layout.astro'
import CompareBody from '../../components/CompareBody.astro'
import { buildCompareJsonLd, seoPagesContent } from '../../i18n/content/seo-pages'

const copy = seoPagesContent.ru.compare
const SITE_ORIGIN = (Astro.site ?? new URL('https://finkley.app')).origin
const jsonLd = buildCompareJsonLd(copy, 'ru', SITE_ORIGIN)
---

<Layout
  title={copy.title}
  description={copy.description}
  active="features"
  lang="ru"
  localized
  jsonLd={jsonLd}
>
  <CompareBody copy={copy} />
</Layout>
