---
import Layout from '../layouts/Layout.astro'
import PricingBody from '../components/PricingBody.astro'
import { buildPricingJsonLd, pricingContent } from '../i18n/content/pricing'

const copy = pricingContent.ru
const SITE_ORIGIN = (Astro.site ?? new URL('https://finkley.app')).origin
const jsonLd = buildPricingJsonLd(
  copy,
  new URL('/pricing', SITE_ORIGIN).toString(),
  SITE_ORIGIN + '/',
)
---

<Layout title={copy.title} description={copy.description} active="pricing" lang="ru" localized jsonLd={jsonLd}>
  <PricingBody copy={copy} locale="ru-RU" />
</Layout>
