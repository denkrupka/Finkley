---
import Layout from '../../../layouts/Layout.astro'
import MessengerBody from '../../../components/MessengerBody.astro'
import { buildFeatureBreadcrumb, featuresContent } from '../../../i18n/content/features'

const copy = featuresContent.pl.messenger
const SITE_ORIGIN = (Astro.site ?? new URL('https://finkley.app')).origin
const breadcrumbLd = buildFeatureBreadcrumb(
  copy.breadcrumbHome,
  copy.breadcrumbSelf,
  new URL('/pl/features/messenger/', SITE_ORIGIN).toString(),
  new URL('/pl/', SITE_ORIGIN).toString(),
)
---

<Layout
  title={copy.title}
  description={copy.description}
  active="features"
  lang="pl"
  localized
  jsonLd={breadcrumbLd}
>
  <MessengerBody copy={copy} />
</Layout>
