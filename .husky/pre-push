#!/usr/bin/env sh
# Pre-push hook: typecheck + lint + format:check перед push.
# Чтобы не пушить заведомо красное в CI.
#
# Почему здесь, а не в pre-commit:
#   - pre-commit запускается на КАЖДЫЙ коммит и должен быть быстрым (<5с).
#     В монорепо `pnpm --filter web exec eslint --fix` на абсолютных путях
#     от lint-staged зависает по 30+ секунд (известный bug — путь не
#     резолвится из cwd=apps/web). Поэтому в pre-commit оставлено только
#     prettier --write (мгновенный форматтер).
#   - pre-push запускается один раз перед публикацией, можно подождать
#     30-40 секунд (lint + typecheck + format).
#
# Почему НЕТ unit tests:
#   - Часть тестов (tests/unit/*-rpc.test.ts, banking-*.test.ts) требуют
#     запущенный локальный Supabase (Docker container). Без него тесты
#     падают, блокируя push даже если код корректен. Полный набор тестов
#     гоняет CI — он всегда поднимает чистый Supabase под себя.
#   - Локально: запускать `pnpm test` руками после изменений в RPC/RLS.

set -e

echo "→ Running typecheck..."
pnpm typecheck

echo "→ Running lint..."
pnpm lint

echo "→ Running format:check..."
pnpm format:check

echo "✓ Pre-push checks passed (full test suite runs in CI)"
