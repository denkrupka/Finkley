# =============================================================================
# tg-userbot service — переменные окружения
# Копировать в /opt/tg-userbot/.env на VM (mode 600, owner tg-userbot)
# =============================================================================

# --- Telegram MTProto credentials (приложение Finkley Messenger из my.telegram.org/apps) ---
TG_API_ID=36979626
TG_API_HASH=8054016a04fcd314fa9161ada1c06b12

# --- Supabase ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=                          # для валидации JWT через /auth/v1/user
SUPABASE_SERVICE_ROLE_KEY=                  # bypass RLS, никогда не светить

# --- Application-level encryption for tg sessions ---
# 32 байта base64. Отдельный от SECRETS_ENCRYPTION_KEY (wFirma) — domain separation.
# Генерация: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
TG_SECRETS_KEY=

# --- Service ---
ENV=prod
PUBLIC_URL=https://userbot.finkley.app
CORS_ORIGINS=https://finkley.app,https://app.finkley.app,https://staging.finkley.app,http://localhost:5173
