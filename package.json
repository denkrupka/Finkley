{
  "name": "finkley",
  "version": "0.0.0",
  "private": true,
  "description": "Управленческий учёт для малых салонов красоты",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "preview": "pnpm --filter web preview",
    "typecheck": "pnpm --filter web typecheck",
    "lint": "pnpm --filter web lint",
    "lint:fix": "pnpm --filter web lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "test": "pnpm --filter web test",
    "test:watch": "pnpm --filter web test:watch",
    "test:e2e": "pnpm --filter web test:e2e",
    "gen:types": "supabase gen types typescript --linked > apps/web/src/types/supabase.ts",
    "gen:types:local": "supabase gen types typescript --local > apps/web/src/types/supabase.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push --linked",
    "db:diff": "supabase db diff",
    "functions:serve": "supabase functions serve",
    "functions:deploy": "supabase functions deploy",
    "tg:check": "node scripts/check-telegram-webhook.mjs",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "supabase": "^2.98.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
